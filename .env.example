OPENAI_API_KEY=
LANGCHAIN_API_KEY=

LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=Autonomous_Driving_Safety_Analyst

CHROMA_VIDEO_DB_PATH=./vectordb/video_db
CHROMA_STANDARDS_DB_PATH=./vectordb/standards_db
CHROMA_LOCAL_STANDARDS_DB_PATH=./vectordb/local_standards_db
VIDEO_COLLECTION_NAME=adas_videos
STANDARDS_COLLECTION_NAME=iso_standards
LOCAL_STANDARDS_COLLECTION_NAME=local_iso_standards

VIDEO_CHUNK_SIZE=400
VIDEO_CHUNK_OVERLAP=50
STANDARDS_CHUNK_SIZE=300
STANDARDS_CHUNK_OVERLAP=40

EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=gpt-4o
OPENAI_MAX_TOKENS=12000
OPENAI_TIMEOUT=300
LOCAL_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Optional open-source draft model backend.
# Default expects Ollama running locally:
#   ollama pull qwen2.5:7b-instruct
#   ollama serve
LOCAL_LLM_PROVIDER=ollama
LOCAL_LLM_BASE_URL=http://localhost:11434
LOCAL_LLM_MODEL=qwen2.5:7b-instruct
LOCAL_LLM_TIMEOUT=300
LOCAL_LLM_NUM_CTX=16384
LOCAL_LLM_NUM_PREDICT=4000
LOCAL_LORA_OLLAMA_MODEL=qwen-safety-lora
LOCAL_LORA_API_URL=
LOCAL_LORA_TIMEOUT=300

# Local speech-to-text input.
# Uses openai-whisper locally, not the OpenAI API. First run may download model weights.
STT_MODEL=base
STT_LANGUAGE=

# Fixed local voice output for terminal testing.
# Keep disabled unless you want every answer synthesized as audio.
TTS_ENABLED=false
TTS_OUTPUT_DIR=./outputs/tts
TTS_AUTOPLAY=false
TTS_MAX_CHARS=3500

# OpenAI TTS settings.
TTS_MODEL=tts-1
TTS_VOICE=alloy
